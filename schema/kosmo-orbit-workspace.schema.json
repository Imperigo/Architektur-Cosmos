{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://architekturkosmos.ch/schema/kosmo-orbit-workspace.schema.json",
  "title": "KosmoOrbit Workspace",
  "description": "Local review-only workspace manifest for KosmoOrbit: roles, tools, projects and gates for the Architecture Kosmos main software.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace",
    "current_user",
    "roles",
    "tools",
    "projects",
    "gates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "current_user": {
      "$ref": "#/$defs/current_user"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate"
      }
    }
  },
  "$defs": {
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "mode", "hardware_profile"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["local_dev", "office_pilot", "production_local"]
        },
        "hardware_profile": {
          "type": "string",
          "enum": ["unknown", "developer_laptop", "kosmo_zentrale_preview", "kosmo_zentrale"]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "current_user": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role_id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role_id": {
          "type": "string"
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "level", "permissions", "ui_mode"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "owner_admin",
            "it_ai_admin",
            "project_lead_architect",
            "design_architect",
            "drafter_efz",
            "intern",
            "apprentice",
            "trial_user"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "enum": ["admin", "lead", "professional", "guided", "learning", "observer"]
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "admin_all",
              "manage_models",
              "manage_updates",
              "approve_public",
              "approve_local",
              "manage_projects",
              "review_gates",
              "use_design",
              "use_draw",
              "use_viz",
              "use_publish",
              "use_data",
              "use_asset",
              "learning_mode",
              "read_only"
            ]
          }
        },
        "ui_mode": {
          "type": "string",
          "enum": ["full_admin", "project_control", "creative_pro", "production_pro", "guided", "learning", "observer"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "status", "primary_roles", "gates"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "kosmo-data",
            "kosmo-asset",
            "kosmo-design",
            "kosmo-prepare",
            "kosmo-draw",
            "kosmo-viz",
            "kosmo-publish",
            "kosmo-zentrale"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": ["data", "asset", "design", "prepare", "draw", "viz", "publish", "control"]
        },
        "status": {
          "type": "string",
          "enum": ["planned", "prototype", "active", "blocked", "external"]
        },
        "primary_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoff_target": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "package_path", "status", "allowed_roles"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,100}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "package_path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["ready", "needs_review", "blocked", "local_only", "approved_local", "approved_public", "unknown"]
        },
        "allowed_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "status", "owner_role", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{2,100}$"
        },
        "type": {
          "type": "string",
          "enum": [
            "source_gate",
            "rights_gate",
            "human_review_gate",
            "model_quality_gate",
            "publish_gate",
            "cost_gate",
            "security_gate"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["ready", "needs_review", "blocked", "local_only", "approved_local", "approved_public", "unknown"]
        },
        "owner_role": {
          "type": "string"
        },
        "tool_id": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
