{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KosmoOrbit",
  "version": "1.0.0",
  "identifier": "ch.architekturkosmos.kosmoorbit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5183",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KosmoOrbit",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Die Architektur-Designzentrale",
    "longDescription": "KosmoOrbit — Entwerfen, Modellieren, Pläne, Visualisierung und Wissen für Architekten. Teil des ArchitekturKosmos."
  }
}
