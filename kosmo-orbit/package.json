{
  "name": "kosmo-orbit-workspace",
  "version": "1.0.0-v1",
  "private": true,
  "description": "KosmoOrbit V1 — die Architektur-Designzentrale des ArchitekturKosmos. Eigenständiger Workspace; die Website im Repo-Root bleibt unberührt.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @kosmo/orbit-app",
    "build": "npm run build -w @kosmo/orbit-app",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
