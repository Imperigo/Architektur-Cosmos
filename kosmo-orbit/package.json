{
  "name": "kosmo-orbit-workspace",
  "version": "0.6.6",
  "private": true,
  "description": "KosmoOrbit V1 — die Architektur-Designzentrale des ArchitekturKosmos. Eigenständiger Workspace; die Website im Repo-Root bleibt unberührt.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @kosmo/orbit-app",
    "build": "npm run build -w @kosmo/orbit-app",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "e2e": "playwright test",
    "security:secrets": "node tools/secret-scan.mjs",
    "test:secret-scan": "node tools/secret-scan.test.mjs",
    "netz-check": "node tools/netz-check.mjs",
    "test:netz-check": "node tools/netz-check.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
