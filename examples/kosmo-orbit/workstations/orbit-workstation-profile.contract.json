  "escalation_rules": [
    "Learning and observer stations escalate to a supervising human before any project decision.",
    "Design and drafting stations escalate to project lead before writes, generation or delivery.",
    "Infrastructure station escalates to owner before costs, external accounts or model/runtime activation.",
    "Owner station still needs explicit owner confirmation before push, public publish or external sync."
  ],
  "next_actions": [
    "Use this contract as the safe local profile map before building persistent users or auth.",
    "Keep every workstation profile review-only until KosmoZentrale runtime and local identity storage are explicitly designed.",
    "Use the profile contract in a future pilot to decide which role-specific surface should be built first."
  ]
