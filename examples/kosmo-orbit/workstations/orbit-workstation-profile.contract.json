  "global_policy": {
    "no_auth_runtime": true,
    "no_user_account_writes": true,
    "no_profile_persistence": true,
    "no_model_starts": true,
    "no_tool_launches": true,
    "no_filesystem_scans": true,
    "no_project_writes": true,
    "no_uploads": true,
    "no_external_accounts": true,
    "no_public_publish": true,
    "no_cost_jobs": true,
    "owner_go_required_for_live": true
